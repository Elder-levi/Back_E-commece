CREATE DATABASE Ecommerce;
USE Ecommerce;

CREATE TABLE Categoria (
    ID INT AUTO_INCREMENT PRIMARY KEY,
    Nome VARCHAR(60) NOT NULL UNIQUE
);

CREATE TABLE Produtos (
    ID INT AUTO_INCREMENT PRIMARY KEY,
    ID_Categoria INT NULL,
    Imagem VARCHAR(200) NOT NULL,
    Nome VARCHAR(100) NOT NULL,
    Descricao TEXT,
    Preco DECIMAL(10,2) NOT NULL CHECK (Preco >= 0),
    Estoque INT NOT NULL DEFAULT 0 CHECK (Estoque >= 0),
    FOREIGN KEY (ID_Categoria) REFERENCES Categoria(ID)
);

CREATE TABLE Usuario (
    ID INT AUTO_INCREMENT PRIMARY KEY,
    Nome VARCHAR(100) NOT NULL,
    Email VARCHAR(100) UNIQUE NOT NULL,
    Senha VARCHAR(255) NOT NULL,   -- usar bcrypt para criptografa a senha, nunca guarda em texto puro
    Role ENUM('USER','ADMIN') NOT NULL DEFAULT 'USER',
    DataDeCriacao DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE Endereco (
    ID INT AUTO_INCREMENT PRIMARY KEY,
    ID_Usuario INT NOT NULL,
    Rua VARCHAR(150) NOT NULL,
    Numero VARCHAR(10) NOT NULL,
    Complemento VARCHAR(100),
    Cidade VARCHAR(80) NOT NULL,
    Estado CHAR(2) NOT NULL,
    CEP VARCHAR(9) NOT NULL,
    FOREIGN KEY (ID_Usuario) REFERENCES Usuario(ID)
);

-- Carrinho: itens que o usuário ainda não finalizou a compra
CREATE TABLE Carrinho (
    ID INT AUTO_INCREMENT PRIMARY KEY,
    ID_Usuario INT NOT NULL,
    ID_Produto INT NOT NULL,
    Quantidade INT NOT NULL DEFAULT 1 CHECK (Quantidade > 0),
    FOREIGN KEY (ID_Usuario) REFERENCES Usuario(ID),
    FOREIGN KEY (ID_Produto) REFERENCES Produtos(ID),
    UNIQUE (ID_Usuario, ID_Produto)  -- evita duplicar o mesmo produto na mesma linha
);

-- Pedido: a compra "fechada"
CREATE TABLE Pedido (
    ID INT AUTO_INCREMENT PRIMARY KEY,
    ID_Usuario INT NOT NULL,
    ID_Endereco INT NOT NULL,
    Status ENUM('PENDENTE','PAGO','ENVIADO','ENTREGUE','CANCELADO') NOT NULL DEFAULT 'PENDENTE',
    ValorTotal DECIMAL(10,2) NOT NULL CHECK (ValorTotal >= 0),
    DataPedido DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (ID_Usuario) REFERENCES Usuario(ID),
    FOREIGN KEY (ID_Endereco) REFERENCES Endereco(ID)
);

-- Itens do pedido: guarda o preço no momento da compra (não referencia Produtos.Preco diretamente)
CREATE TABLE ItemPedido (
    ID INT AUTO_INCREMENT PRIMARY KEY,
    ID_Pedido INT NOT NULL,
    ID_Produto INT NOT NULL,
    Quantidade INT NOT NULL CHECK (Quantidade > 0),
    PrecoUnitario DECIMAL(10,2) NOT NULL CHECK (PrecoUnitario >= 0),
    FOREIGN KEY (ID_Pedido) REFERENCES Pedido(ID),
    FOREIGN KEY (ID_Produto) REFERENCES Produtos(ID)
);

